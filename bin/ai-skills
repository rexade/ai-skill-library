#!/usr/bin/env bash
set -euo pipefail

LIBRARY_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PACKS_DIR="$LIBRARY_ROOT/packs"

cmd="${1:-}"
pack="${2:-}"

case "$cmd" in
  use)
    if [[ -z "$pack" ]]; then
      echo "Usage: ai-skills use <pack>" >&2; exit 1
    fi
    if [[ "$pack" == */* || "$pack" == .* ]]; then
      echo "Ogiltigt pack-namn: '$pack'" >&2; exit 1
    fi
    if [[ "$(pwd -P)" == "$(cd "$LIBRARY_ROOT" && pwd -P)" ]]; then
      echo "Kör ai-skills från ditt projektbibliotek, inte från ai-skill-library-rooten." >&2; exit 1
    fi
    if [[ "$pack" == "plain" ]]; then
      skills_dir=".claude/skills"
      mkdir -p "$skills_dir"
      rm -f "$skills_dir"/*.md
      echo "plain" > .claude/active-skills.txt
      if [[ -d .git ]]; then
        gitignore=".gitignore"
        touch "$gitignore"
        grep -qxF ".claude/skills/" "$gitignore" || echo ".claude/skills/" >> "$gitignore"
        grep -qxF ".claude/active-skills.txt" "$gitignore" || echo ".claude/active-skills.txt" >> "$gitignore"
      fi
      echo "✓ Pack 'plain' aktiverat — inga skills laddade"
      exit 0
    fi
    pack_path="$PACKS_DIR/$pack"
    if [[ ! -d "$pack_path" ]]; then
      echo "Pack '$pack' finns inte. Kör 'ai-skills list'." >&2; exit 1
    fi
    shopt -s nullglob
    md_files=("$pack_path"/*.md)
    shopt -u nullglob
    if [[ ${#md_files[@]} -eq 0 ]]; then
      echo "Pack '$pack' innehåller inga .md-filer." >&2; exit 1
    fi
    skills_dir=".claude/skills"
    mkdir -p "$skills_dir"
    rm -f "$skills_dir"/*.md
    # Ladda alltid base-pack först (delade skills)
    base_files=("$PACKS_DIR/base"/*.md)
    [[ ${#base_files[@]} -gt 0 ]] && cp "${base_files[@]}" "$skills_dir/"
    cp "${md_files[@]}" "$skills_dir/"
    echo "$pack" > .claude/active-skills.txt
    # Ensure .claude/skills/ and active-skills.txt are gitignored in the project
    if [[ -d .git ]]; then
      gitignore=".gitignore"
      touch "$gitignore"
      grep -qxF ".claude/skills/" "$gitignore" || echo ".claude/skills/" >> "$gitignore"
      grep -qxF ".claude/active-skills.txt" "$gitignore" || echo ".claude/active-skills.txt" >> "$gitignore"
    fi
    echo "✓ Pack '$pack' aktiverat i $skills_dir/"
    ls "$skills_dir/"
    ;;
  clear)
    rm -f .claude/skills/*.md .claude/active-skills.txt
    echo "✓ Skills rensade"
    ;;
  status)
    if [[ -f .claude/active-skills.txt ]]; then
      pack=$(cat .claude/active-skills.txt)
      echo "Aktivt pack: $pack"
      echo "Skills:"
      shopt -s nullglob
      local_md=(.claude/skills/*.md)
      shopt -u nullglob
      for f in "${local_md[@]}"; do
        echo "  - $(basename "$f" .md)"
      done
    else
      echo "Inget pack aktivt (plain mode)"
    fi
    ;;
  list)
    echo "Tillgängliga packs:"
    echo "  - plain"
    ls "$PACKS_DIR/" | sed 's/^/  - /'
    ;;
  *)
    echo "Användning: ai-skills <use|clear|status|list> [pack]" >&2
    exit 1
    ;;
esac
